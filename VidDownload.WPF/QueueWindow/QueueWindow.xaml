<Window x:Class="VidDownload.WPF.QueueWindow.QueueWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:local="clr-namespace:VidDownload.WPF.Control"
        mc:Ignorable="d"
        Title="Очередь загрузок" WindowStartupLocation="CenterOwner" Width="700" Height="500"
        MinWidth="500" MinHeight="300" ResizeMode="CanResize">
    <Grid Background="#FF1D1D1D">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TextBoxAddUrl" Grid.Column="0" Height="28" FontSize="14" FontFamily="Cascadia Code SemiLight"
                     VerticalContentAlignment="Center" Background="White" Margin="0,0,10,0"
                     ToolTip="Введите ссылку и нажмите Enter или кнопку Добавить"
                     KeyDown="TextBoxAddUrl_KeyDown"/>
            <Button x:Name="ButAddUrl" Grid.Column="1" Content="Добавить" Width="100" Height="28"
                    FontFamily="Cascadia Code" FontSize="14" FontWeight="Bold" Click="ButAddUrl_Click"/>
        </Grid>

        <Grid Grid.Row="1" Margin="10,0,10,0">
            <ListView x:Name="ListViewQueue" Background="#FF2B2B2B" BorderThickness="0"
                      FontFamily="Cascadia Code" FontSize="13" Foreground="White"
                      SelectionMode="Extended">
                <ListView.ItemTemplate>
                    <DataTemplate DataType="local:QueueItem">
                        <Border BorderBrush="#FF3A3A3A" BorderThickness="0,0,0,1" Padding="5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Border Width="40" Height="30" Background="#FF3A3A3A" CornerRadius="3">
                                        <TextBlock Text="🎬" FontSize="20" TextAlignment="Center"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Url}" FontSize="11" Foreground="#FF888888"
                                               TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding Status}" Foreground="#FFAAAAAA"
                                               HorizontalAlignment="Right" FontSize="12"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="ButRemoveSelected" Grid.Column="0" Content="Удалить" Width="90" Height="30"
                    FontFamily="Cascadia Code" FontSize="14" FontWeight="Bold" Click="ButRemoveSelected_Click"
                    Margin="0,0,10,0"/>
            <Button x:Name="ButClear" Grid.Column="1" Content="Очистить" Width="90" Height="30"
                    FontFamily="Cascadia Code" FontSize="14" FontWeight="Bold" Click="ButClear_Click"
                    Margin="0,0,0,0"/>
            <TextBlock x:Name="TextQueueStatus" Grid.Column="2" Text="" Foreground="#FFAAAAAA"
                       FontFamily="Cascadia Code" FontSize="13" VerticalAlignment="Center"
                       HorizontalAlignment="Center" Margin="10,0"/>
            <Button x:Name="ButStartQueue" Grid.Column="3" Content="Скачать всё" Width="110" Height="36"
                    FontFamily="Cascadia Code" FontSize="16" FontWeight="Bold" Margin="0,0,10,0"
                    Background="#FFFF4F4F" Foreground="White" Click="ButStartQueue_Click"/>
            <Button x:Name="ButStopQueue" Grid.Column="4" Content="Стоп" Width="80" Height="36"
                    FontFamily="Cascadia Code" FontSize="16" FontWeight="Bold"
                    Background="#FF4F4F4F" Foreground="White" Click="ButStopQueue_Click"
                    IsEnabled="False"/>
        </Grid>
    </Grid>
</Window>
