<Window x:Class="VidDownload.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:converters="clr-namespace:VidDownload.WPF.Converters"
        mc:Ignorable="d"
        Title="VidDownload" WindowStartupLocation="CenterScreen" Icon="/icon.png" ResizeMode="CanMinimize" SizeToContent="WidthAndHeight" WindowStyle="ThreeDBorderWindow" Width="650" MinWidth="650">
    <Window.Resources>
        <converters:BooleanInvertConverter x:Key="InvertBool"/>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid Background="Black">
        <Grid Background="#FF1D1D1D">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Height="auto">
                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                    <Label Content="{Binding LinkLabelText}" hc:Theme.Skin="Dark" Height="40" Margin="20, 0" FontFamily="Cascadia Code" FontSize="22" Foreground="White" FontWeight="Bold" Background="{x:Null}" ScrollViewer.VerticalScrollBarVisibility="Disabled" BorderThickness="0,0,0,0" Panel.ZIndex="0"/>
                    <TextBox Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}" hc:Theme.Skin="Dark" Margin="20, 0" VerticalAlignment="Top" Height="36" FontSize="16" FontFamily="Cascadia Code SemiLight" VerticalContentAlignment="Center" SelectionBrush="#FDFF5252" Width="610"/>
                </StackPanel>
            </Grid>
            <Grid Grid.Row="1" HorizontalAlignment="Center" Margin="0,30,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" HorizontalAlignment="Left" Width="200" Height="320" Background="#FF2B2B2B">
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0, 10">
                        <Label Content="Разрешение:" Visibility="{Binding IsVideoOptionsVisible, Converter={StaticResource BoolToVis}}" Margin="20, 0, 0, 0" HorizontalAlignment="Left" VerticalAlignment="Top" hc:Theme.Skin="Dark" Foreground="White" FontFamily="Cascadia Code" Height="29" FontSize="16" FontWeight="Bold" Background="{x:Null}" Padding="0,0,0,0" UseLayoutRounding="False" BorderThickness="0,0,0,0"/>
                        <ComboBox ItemsSource="{Binding Resolutions}" SelectedItem="{Binding SelectedResolution}" Visibility="{Binding IsVideoOptionsVisible, Converter={StaticResource BoolToVis}}" Height="22" Margin="20, 0" VerticalAlignment="Top" HorizontalAlignment="Left" Width="150" FontFamily="Cascadia Code" FontWeight="Bold" hc:Theme.Skin="Dark" BorderThickness="0,0,0,0" FontSize="14"/>
                        <Label Content="Кодек:" Visibility="{Binding IsVideoOptionsVisible, Converter={StaticResource BoolToVis}}" Margin="20, 0" HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="White" FontFamily="Cascadia Code" Height="27" FontSize="16" FontWeight="Bold" Background="{x:Null}" BorderThickness="0,0,0,0" Padding="0,0,0,0"/>
                        <ComboBox ItemsSource="{Binding Codecs}" SelectedItem="{Binding SelectedCodec}" Visibility="{Binding IsVideoOptionsVisible, Converter={StaticResource BoolToVis}}" Height="22" Margin="20, 0" VerticalAlignment="Top" HorizontalAlignment="Left" Width="150" FontFamily="Raleway" FontWeight="Bold" hc:Theme.Skin="Dark" BorderThickness="0,0,0,0" FontSize="14"/>
                        <Label Content="Аудио формат:" Visibility="{Binding IsAudioOptionsVisible, Converter={StaticResource BoolToVis}}" Margin="20, 0" HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="White" FontFamily="Cascadia Code" FontSize="16" Background="{x:Null}" BorderThickness="0,0,0,0" Padding="0,0,0,0" FontWeight="Bold"/>
                        <ComboBox ItemsSource="{Binding AudioFormats}" SelectedItem="{Binding SelectedAudioFormat}" Visibility="{Binding IsAudioOptionsVisible, Converter={StaticResource BoolToVis}}" HorizontalAlignment="Left" Margin="20, 0" VerticalAlignment="Top" Width="150" FontFamily="Cascadia Code" FontWeight="Bold" hc:Theme.Skin="Dark" BorderThickness="0,0,0,0" FontSize="14"/>
                        <Label Content="Расширение файла:" Visibility="{Binding IsVideoOptionsVisible, Converter={StaticResource BoolToVis}}" Margin="20, 0" HorizontalAlignment="Left" VerticalAlignment="Top" FontFamily="Cascadia Code" Foreground="White" FontSize="16" FontWeight="Bold" Background="{x:Null}" Padding="0,0,0,0" BorderThickness="0,0,0,0"/>
                        <ComboBox ItemsSource="{Binding Formats}" SelectedItem="{Binding SelectedFormat}" Visibility="{Binding IsVideoOptionsVisible, Converter={StaticResource BoolToVis}}" HorizontalAlignment="Left" Margin="20, 0" VerticalAlignment="Top" Width="150" FontFamily="Cascadia Code" FontWeight="Bold" hc:Theme.Skin="Dark" BorderThickness="0,0,0,0" FontSize="14"/>
                    </StackPanel>
                </Grid>
                <Grid Grid.Column="1" HorizontalAlignment="Left" Background="#FF3A3A3A" Width="260" Height="320">
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                        <CheckBox IsChecked="{Binding IsPlaylist}" Content="Скачать весь плейлист" Foreground="White" Margin="20, 5" HorizontalAlignment="Left" FontFamily="Cascadia Code" FontSize="16" VerticalContentAlignment="Center" VerticalAlignment="Top" Grid.RowSpan="1" Grid.ColumnSpan="1" FontWeight="Bold"/>
                        <CheckBox IsChecked="{Binding IsAudioOnly}" Content="Только аудио" HorizontalAlignment="Left" Margin="20, 5" VerticalAlignment="Top" FontFamily="Cascadia Code" Foreground="White" FontSize="16" Width="190" FontWeight="Bold"/>
                        <CheckBox IsChecked="{Binding IsReEncode}" IsEnabled="{Binding IsAudioOnly, Converter={StaticResource InvertBool}}" Content="Перекодировать видео" HorizontalAlignment="Left" Margin="20, 5" VerticalAlignment="Top" FontFamily="Cascadia Code" FontSize="16" Foreground="White" FontWeight="Bold"/>
                        <Line X1="0" X2="200" Y1="0" Y2="0" Stroke="#FF555555" StrokeThickness="1" Margin="20, 5" HorizontalAlignment="Left" Stretch="None"/>
                        <CheckBox IsChecked="{Binding IsDownloadSubtitles}" Content="Скачать субтитры" HorizontalAlignment="Left" Margin="20, 5" VerticalAlignment="Top" FontFamily="Cascadia Code" FontSize="16" Foreground="White" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Visibility="{Binding IsDownloadSubtitles, Converter={StaticResource BoolToVis}}" Margin="20, 0">
                            <Label Content="Язык:" Foreground="White" FontFamily="Cascadia Code" FontSize="14" FontWeight="Bold" Padding="0,2,5,0" Background="{x:Null}" BorderThickness="0"/>
                            <ComboBox ItemsSource="{Binding SubtitleLanguages}" SelectedItem="{Binding SelectedSubtitleLanguage}" Height="24" Width="120" FontFamily="Cascadia Code" FontWeight="Bold" Background="White" BorderThickness="0" FontSize="13"/>
                        </StackPanel>
                        <CheckBox IsChecked="{Binding IsEmbedSubtitles}" Content="Встроить субтитры" Visibility="{Binding IsDownloadSubtitles, Converter={StaticResource BoolToVis}}" HorizontalAlignment="Left" Margin="20, 5" VerticalAlignment="Top" FontFamily="Cascadia Code" FontSize="16" Foreground="White" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Grid>
            <Grid Grid.Row="2" Height="auto">
                <StackPanel Margin="0, 0, 0, 10">
                    <Label Content="{Binding StatusMessage}" Width="610" HorizontalAlignment="Left" Margin="20,0,20,0" FontFamily="Cascadia Code SemiLight" Foreground="White" Background="{x:Null}" Padding="0,0,0,0" BorderThickness="0,0,0,0" ScrollViewer.VerticalScrollBarVisibility="Disabled"/>
                    <ProgressBar Value="{Binding ProgressPercent}" Margin="20, 0" Height="28" VerticalAlignment="Top" Foreground="#FDFF5252" FontFamily="Cascadia Code" FontWeight="Bold" FontSize="14"/>
                    <Grid Margin="20, 2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Label Content="Скорость: " Foreground="White" FontFamily="Cascadia Code" FontSize="13" Padding="0" BorderThickness="0" Background="#FF1D1D1D"/>
                            <Label Content="{Binding SpeedText}" Foreground="White" FontFamily="Cascadia Code" FontSize="13" Padding="0" BorderThickness="0" Background="#FF1D1D1D"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                            <Label Content="ETA: " Foreground="White" FontFamily="Cascadia Code" FontSize="13" Padding="0" BorderThickness="0" Background="#FF1D1D1D"/>
                            <Label Content="{Binding EtaText}" Foreground="White" FontFamily="Cascadia Code" FontSize="13" Padding="0" BorderThickness="0" Background="#FF1D1D1D"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Label Content="Размер: " Foreground="White" FontFamily="Cascadia Code" FontSize="13" Padding="0" BorderThickness="0" Background="#FF1D1D1D"/>
                            <Label Content="{Binding TotalSizeText}" Foreground="White" FontFamily="Cascadia Code" FontSize="13" Padding="0" BorderThickness="0" Background="#FF1D1D1D"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0, 10">
                        <Button Content="Скачать" Command="{Binding DownloadCommand}" Height="45" Width="250" hc:Theme.Skin="Dark" Background="#FFBB1818" Foreground="White" BorderBrush="White" FontFamily="Cascadia Code" FontSize="27" FontWeight="Bold" Margin="0,0,10,0"/>
                        <Button Content="Отмена" Command="{Binding CancelCommand}" Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}" Height="45" Width="100" Background="#FF444444" Foreground="White" BorderBrush="White" FontFamily="Cascadia Code" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0, 5">
                        <Label Content="FFmpeg: " Foreground="White" FontFamily="Cascadia Code" FontSize="13" Padding="0" BorderThickness="0" Background="#FF1D1D1D"/>
                        <Label Content="{Binding FfmpegVersion}" Foreground="White" FontFamily="Cascadia Code" FontSize="13" Padding="0" BorderThickness="0" Background="#FF1D1D1D"/>
                        <Button Content="Проверить обновление" Command="{Binding CheckFFmpegUpdateCommand}" Height="24" Padding="5,0" Margin="10,0,0,0" FontFamily="Cascadia Code" FontSize="11" FontWeight="Bold"/>
                    </StackPanel>
                    <Grid HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" Margin="0, 0, 10, 0">
                            <Button Content="Открыть папку с видео" Command="{Binding OpenFolderCommand}" VerticalAlignment="Top" Height="30" Width="200" FontFamily="Cascadia Code" FontSize="14" FontWeight="Bold"/>
                        </Grid>
                        <Grid Grid.Column="1" Margin="0, 0, 10, 0">
                            <Button Content="История" Command="{Binding OpenHistoryCommand}" hc:Theme.Skin="Dark" HorizontalAlignment="Left" VerticalAlignment="Top" Width="100" Height="30" FontFamily="Cascadia Code" FontWeight="Bold" FontSize="14"/>
                        </Grid>
                        <Grid Grid.Column="2" Margin="0, 0, 10, 0">
                            <Button Content="Конвертер" Command="{Binding OpenConverterCommand}" hc:Theme.Skin="Dark" HorizontalAlignment="Left" VerticalAlignment="Top" Width="100" Height="30" FontFamily="Cascadia Code" FontWeight="Bold" FontSize="14"/>
                        </Grid>
                        <Grid Grid.Column="3">
                            <Button Content="?" Command="{Binding OpenHelpCommand}" HorizontalAlignment="Left" VerticalAlignment="Top" Width="30" Height="30" FontFamily="Cascadia Code" FontWeight="Bold" FontSize="14"/>
                        </Grid>
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
