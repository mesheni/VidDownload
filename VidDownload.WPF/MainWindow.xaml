<Window x:Class="VidDownload.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:converters="clr-namespace:VidDownload.WPF.Converters"
        mc:Ignorable="d"
        Title="VidDownload" WindowStartupLocation="CenterScreen" Icon="/icon.png" ResizeMode="CanMinimize" SizeToContent="WidthAndHeight" WindowStyle="ThreeDBorderWindow" Width="650" MinWidth="650">
    <Window.Resources>
        <converters:BooleanInvertConverter x:Key="InvertBool"/>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid Background="Black">
        <Grid Background="#FF1D1D1D">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Height="auto">
                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                    <Label Content="{Binding LinkLabelText}" Height="40" Margin="20, 0" FontFamily="Cascadia Code" FontSize="22" Foreground="White" FontWeight="Bold" Background="{x:Null}" ScrollViewer.VerticalScrollBarVisibility="Disabled" BorderThickness="0,0,0,0" Panel.ZIndex="0"/>
                    <TextBox Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}" Margin="20, 0" VerticalAlignment="Top" Height="36" FontSize="16" FontFamily="Cascadia Code SemiLight" VerticalContentAlignment="Center" SelectionBrush="#FDFF5252" Width="610" Background="White"/>
                </StackPanel>
            </Grid>
            <Grid Grid.Row="1" HorizontalAlignment="Center" Margin="0,30,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" HorizontalAlignment="Left" Width="200" Height="200" Background="#FF2B2B2B">
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0, 10">
                        <Label Content="Разрешение:" Visibility="{Binding IsVideoOptionsVisible, Converter={StaticResource BoolToVis}}" Margin="20, 0, 0, 0" HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="White" FontFamily="Cascadia Code" Height="29" FontSize="16" FontWeight="Bold" Background="{x:Null}" Padding="0,0,0,0" UseLayoutRounding="False" BorderThickness="0,0,0,0"/>
                        <ComboBox ItemsSource="{Binding Resolutions}" SelectedItem="{Binding SelectedResolution}" Visibility="{Binding IsVideoOptionsVisible, Converter={StaticResource BoolToVis}}" Height="22" Margin="20, 0" VerticalAlignment="Top" HorizontalAlignment="Left" Width="150" FontFamily="Cascadia Code" FontWeight="Bold" Background="White" BorderThickness="0,0,0,0" FontSize="14"/>
                        <Label Content="Кодек:" Visibility="{Binding IsVideoOptionsVisible, Converter={StaticResource BoolToVis}}" Margin="20, 0" HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="White" FontFamily="Cascadia Code" Height="27" FontSize="16" FontWeight="Bold" Background="{x:Null}" BorderThickness="0,0,0,0" Padding="0,0,0,0"/>
                        <ComboBox ItemsSource="{Binding Codecs}" SelectedItem="{Binding SelectedCodec}" Visibility="{Binding IsVideoOptionsVisible, Converter={StaticResource BoolToVis}}" Height="22" Margin="20, 0" VerticalAlignment="Top" HorizontalAlignment="Left" Width="150" FontFamily="Raleway" FontWeight="Bold" Background="White" BorderThickness="0,0,0,0" FontSize="14"/>
                        <Label Content="Аудио формат:" Visibility="{Binding IsAudioOptionsVisible, Converter={StaticResource BoolToVis}}" Margin="20, 0" HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="White" FontFamily="Cascadia Code" FontSize="16" Background="{x:Null}" BorderThickness="0,0,0,0" Padding="0,0,0,0" FontWeight="Bold"/>
                        <ComboBox ItemsSource="{Binding AudioFormats}" SelectedItem="{Binding SelectedAudioFormat}" Visibility="{Binding IsAudioOptionsVisible, Converter={StaticResource BoolToVis}}" HorizontalAlignment="Left" Margin="20, 0" VerticalAlignment="Top" Width="150" FontFamily="Cascadia Code" FontWeight="Bold" Background="White" BorderThickness="0,0,0,0" FontSize="14"/>
                        <Label Content="Расширение файла:" Visibility="{Binding IsVideoOptionsVisible, Converter={StaticResource BoolToVis}}" Margin="20, 0" HorizontalAlignment="Left" VerticalAlignment="Top" FontFamily="Cascadia Code" Foreground="White" FontSize="16" FontWeight="Bold" Background="{x:Null}" Padding="0,0,0,0" BorderThickness="0,0,0,0"/>
                        <ComboBox ItemsSource="{Binding Formats}" SelectedItem="{Binding SelectedFormat}" Visibility="{Binding IsVideoOptionsVisible, Converter={StaticResource BoolToVis}}" HorizontalAlignment="Left" Margin="20, 0" VerticalAlignment="Top" Width="150" FontFamily="Cascadia Code" FontWeight="Bold" Background="White" BorderThickness="0,0,0,0" FontSize="14"/>
                    </StackPanel>
                </Grid>
                <Grid Grid.Column="1" HorizontalAlignment="Left" Background="#FF3A3A3A" Width="260" Height="200">
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                        <CheckBox IsChecked="{Binding IsPlaylist}" Content="Скачать весь плейлист" Foreground="White" Margin="20, 5" HorizontalAlignment="Left" FontFamily="Cascadia Code" FontSize="16" VerticalContentAlignment="Center" VerticalAlignment="Top" Grid.RowSpan="1" Grid.ColumnSpan="1" FontWeight="Bold"/>
                        <CheckBox IsChecked="{Binding IsAudioOnly}" Content="Только аудио" HorizontalAlignment="Left" Margin="20, 5" VerticalAlignment="Top" FontFamily="Cascadia Code" Foreground="White" FontSize="16" Width="190" FontWeight="Bold"/>
                        <CheckBox IsChecked="{Binding IsReEncode}" IsEnabled="{Binding IsAudioOnly, Converter={StaticResource InvertBool}}" Content="Перекодировать видео" HorizontalAlignment="Left" Margin="20, 5" VerticalAlignment="Top" FontFamily="Cascadia Code" FontSize="16" Foreground="White" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Grid>
            <Grid Grid.Row="2" Height="auto">
                <StackPanel Margin="0, 0, 0, 10">
                    <Label Content="{Binding StatusMessage}" Width="610" HorizontalAlignment="Left" Margin="20,0,20,0" FontFamily="Cascadia Code SemiLight" Foreground="White" Background="{x:Null}" Padding="0,0,0,0" BorderThickness="0,0,0,0" ScrollViewer.VerticalScrollBarVisibility="Disabled"/>
                    <ProgressBar Value="{Binding ProgressPercent}" Margin="20, 0" Height="28" VerticalAlignment="Top" Foreground="#FDFF5252" FontFamily="Cascadia Code" FontWeight="Bold" FontSize="14"/>
                    <Button Content="Скачать" Command="{Binding DownloadCommand}" VerticalAlignment="Top" Margin="0, 10" Height="45" Width="350" Background="#FFFF4F4F" Foreground="White" BorderBrush="White" FontFamily="Cascadia Code" FontSize="27" FontWeight="Bold"/>
                    <Grid HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" Margin="0, 0, 10, 0">
                            <Button Content="Открыть папку с видео" Command="{Binding OpenFolderCommand}" VerticalAlignment="Top" Height="30" Width="200" FontFamily="Cascadia Code" FontSize="14" FontWeight="Bold"/>
                        </Grid>
                        <Grid Grid.Column="1" Margin="0, 0, 10, 0">
                            <Button Content="Конвертер" Command="{Binding OpenConverterCommand}" HorizontalAlignment="Left" VerticalAlignment="Top" Width="100" Height="30" FontFamily="Cascadia Code" FontWeight="Bold" Background="#FF75FFAF" FontSize="14"/>
                        </Grid>
                        <Grid Grid.Column="2">
                            <Button Content="?" Command="{Binding OpenHelpCommand}" HorizontalAlignment="Left" VerticalAlignment="Top" Width="30" Height="30" FontFamily="Cascadia Code" FontWeight="Bold" FontSize="14"/>
                        </Grid>
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
