<Window x:Name="FormMain" x:Class="VidDownload.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:local="clr-namespace:VidDownload.WPF"
        xmlns:ctrl="clr-namespace:VidDownload.WPF.Control"
        mc:Ignorable="d"
        Title="VidDownload" WindowStartupLocation="CenterScreen" Icon="/icon.png"
        ResizeMode="CanMinimize" WindowStyle="ThreeDBorderWindow"
        Width="950" MinWidth="900" SizeToContent="Height">

    <Grid Background="Black">
        <Grid Background="#FF1D1D1D">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="560"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- ===== ЛЕВАЯ КОЛОНКА: основной функционал ===== -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Height="auto">
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                        <Label x:Name="LabelLink" Height="40" Content="Поле для ссылки на видео:"
                               Margin="20, 0" FontFamily="Cascadia Code" FontSize="22"
                               Foreground="White" FontWeight="Bold" Background="{x:Null}"
                               Padding="0,0,0,0"/>
                        <TextBox x:Name="TextBoxURL" Margin="20, 0" VerticalAlignment="Top" Height="36"
                                 FontSize="16" FontFamily="Cascadia Code SemiLight"
                                 VerticalContentAlignment="Center" SelectionBrush="#FDFF5252"
                                 Width="520" Background="White"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" HorizontalAlignment="Center" Margin="10,30,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" HorizontalAlignment="Left" Width="200" Height="200"
                          Background="#FF2B2B2B">
                        <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0, 10">
                            <Label x:Name="LabelRes" Content="Разрешение:" Margin="20, 0, 0, 0"
                                   HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="White"
                                   FontFamily="Cascadia Code" Height="29" FontSize="16" FontWeight="Bold"
                                   Background="{x:Null}" Padding="0,0,0,0"/>
                            <ComboBox x:Name="ComboRes" Height="22" Margin="20, 0"
                                      VerticalAlignment="Top" HorizontalAlignment="Left" Width="150"
                                      FontFamily="Cascadia Code" FontWeight="Bold"
                                      Background="White" FontSize="14">
                                <ComboBoxItem Content="" FontFamily="Cascadia Code" FontWeight="Bold"/>
                                <ComboBoxItem Content="144" FontFamily="Cascadia Code" FontWeight="Bold"/>
                                <ComboBoxItem Content="240" FontFamily="Cascadia Code" FontWeight="Bold"/>
                                <ComboBoxItem Content="360" FontFamily="Cascadia Code" FontWeight="Bold"/>
                                <ComboBoxItem Content="480" FontFamily="Cascadia Code" FontWeight="Bold"/>
                                <ComboBoxItem Content="720" FontFamily="Cascadia Code" FontWeight="Bold"/>
                                <ComboBoxItem Content="1080" FontFamily="Cascadia Code" FontWeight="Bold"/>
                                <ComboBoxItem Content="1440" FontFamily="Cascadia Code" FontWeight="Bold"/>
                                <ComboBoxItem Content="2160" FontFamily="Cascadia Code" FontWeight="Bold"/>
                            </ComboBox>

                            <Label x:Name="LabelCodec" Content="Кодек:" Margin="20, 0"
                                   HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="White"
                                   FontFamily="Cascadia Code" Height="27" FontSize="16" FontWeight="Bold"
                                   Background="{x:Null}" Padding="0,0,0,0"/>
                            <ComboBox x:Name="ComboCodec" Height="22" Margin="20, 0"
                                      VerticalAlignment="Top" HorizontalAlignment="Left" Width="150"
                                      FontFamily="Raleway" FontWeight="Bold" Background="White" FontSize="14">
                                <ComboBoxItem Content="" FontFamily="Cascadia Code" FontWeight="Bold"/>
                                <ComboBoxItem Content="av01" FontFamily="Cascadia Code" FontWeight="Bold"/>
                                <ComboBoxItem Content="vp9.2" FontFamily="Cascadia Code" FontWeight="Bold"/>
                                <ComboBoxItem Content="vp9" FontFamily="Cascadia Code" FontWeight="Bold"/>
                                <ComboBoxItem Content="h265" FontFamily="Cascadia Code" FontWeight="Bold"/>
                                <ComboBoxItem Content="h264" FontFamily="Cascadia Code" FontWeight="Bold"/>
                                <ComboBoxItem Content="vp8" FontFamily="Cascadia Code" FontWeight="Bold"/>
                                <ComboBoxItem Content="h263" FontFamily="Cascadia Code" FontWeight="Bold"/>
                            </ComboBox>

                            <Label x:Name="LabelCheckAudio" Content="Аудио формат:" Margin="20, 0"
                                   HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="White"
                                   FontFamily="Cascadia Code" FontSize="16" Visibility="Collapsed"
                                   Background="{x:Null}" Padding="0,0,0,0" FontWeight="Bold"/>
                            <ComboBox x:Name="ComboAudio" HorizontalAlignment="Left" Margin="20, 0"
                                      VerticalAlignment="Top" Width="150" Visibility="Collapsed"
                                      FontFamily="Cascadia Code" FontWeight="Bold"
                                      Background="White" FontSize="14">
                                <ComboBoxItem Content="" FontFamily="Cascadia Code" FontWeight="Bold"/>
                                <ComboBoxItem Content="mp3" FontFamily="Cascadia Code" FontWeight="Bold"/>
                                <ComboBoxItem Content="3gp" FontFamily="Cascadia Code" FontWeight="Bold"/>
                                <ComboBoxItem Content="flac" FontFamily="Cascadia Code" FontWeight="Bold"/>
                                <ComboBoxItem Content="wav" FontFamily="Cascadia Code" FontWeight="Bold"/>
                                <ComboBoxItem Content="aac" FontFamily="Cascadia Code" FontWeight="Bold"/>
                                <ComboBoxItem Content="m4a" FontFamily="Cascadia Code" FontWeight="Bold"/>
                            </ComboBox>

                            <Label x:Name="LabelFormat" Content="Расширение файла:" Margin="20, 0"
                                   HorizontalAlignment="Left" VerticalAlignment="Top"
                                   FontFamily="Cascadia Code" Foreground="White" FontSize="16"
                                   FontWeight="Bold" Background="{x:Null}" Padding="0,0,0,0"/>
                            <ComboBox x:Name="ComboFormat" HorizontalAlignment="Left" Margin="20, 0"
                                      VerticalAlignment="Top" Width="150" FontFamily="Cascadia Code"
                                      FontWeight="Bold" Background="White" FontSize="14"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Column="1" HorizontalAlignment="Left" Background="#FF3A3A3A"
                          Width="260" Height="200">
                        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                            <CheckBox x:Name="CheckBoxPlaylist" Content="Скачать весь плейлист"
                                      Foreground="White" Margin="20, 5" HorizontalAlignment="Left"
                                      FontFamily="Cascadia Code" FontSize="16" VerticalContentAlignment="Center"
                                      VerticalAlignment="Top" IsChecked="False"
                                      Checked="CheckBoxPlaylist_Checked" Unchecked="CheckBoxPlaylist_Unchecked"
                                      FontWeight="Bold"/>
                            <CheckBox x:Name="CheckAudio" Content="Только аудио" HorizontalAlignment="Left"
                                      Margin="20, 5" VerticalAlignment="Top" FontFamily="Cascadia Code"
                                      Foreground="White" FontSize="16" Width="190"
                                      Checked="CheckAudio_Checked" Unchecked="CheckAudio_Unchecked"
                                      FontWeight="Bold"/>
                            <CheckBox x:Name="CheckCoder" Content="Перекодировать видео"
                                      HorizontalAlignment="Left" Margin="20, 5" VerticalAlignment="Top"
                                      FontFamily="Cascadia Code" FontSize="16" Foreground="White"
                                      Checked="CheckCoder_Checked" Unchecked="CheckCoder_Unchecked"
                                      FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Grid>

                <Grid Grid.Row="2" Height="auto">
                    <StackPanel Margin="0, 0, 0, 10">
                        <Label x:Name="labelInfo" Content="" Width="520" HorizontalAlignment="Left"
                               Margin="20,0,20,0" FontFamily="Cascadia Code SemiLight" Foreground="White"
                               Background="{x:Null}" Padding="0,0,0,0"/>
                        <ProgressBar x:Name="ProgressBarMain" Margin="20, 0" Height="28"
                                     VerticalAlignment="Top" Foreground="#FDFF5252"
                                     FontFamily="Cascadia Code" FontWeight="Bold" FontSize="14"
                                     Width="520"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0, 10">
                            <Button x:Name="ButDownload" Content="Скачать" VerticalAlignment="Top"
                                    Height="45" Width="240" Background="#FFFF4F4F" Foreground="White"
                                    BorderBrush="White" FontFamily="Cascadia Code" FontSize="27"
                                    Click="ButDownload_Click" FontWeight="Bold" Margin="0,0,10,0"/>
                            <Button x:Name="ButStop" Content="Стоп" VerticalAlignment="Top" Height="45"
                                    Width="100" Background="#FF4F4F4F" Foreground="White"
                                    BorderBrush="White" FontFamily="Cascadia Code" FontSize="20"
                                    Click="ButStop_Click" FontWeight="Bold" IsEnabled="False"/>
                        </StackPanel>

                        <Grid HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" Margin="0, 0, 10, 0">
                                <Button x:Name="ButOpenFolder" Content="Открыть папку с видео"
                                        VerticalAlignment="Top" Height="30" Width="200"
                                        FontFamily="Cascadia Code" Click="ButOpenFolder_Click"
                                        FontSize="14" FontWeight="Bold"/>
                            </Grid>
                            <Grid Grid.Column="1" Margin="0, 0, 10, 0">
                                <Button x:Name="ButtonConv" Content="Конвертер" HorizontalAlignment="Left"
                                        VerticalAlignment="Top" Width="100" Height="30"
                                        Click="ButtonConvert_Click" FontFamily="Cascadia Code"
                                        FontWeight="Bold" Background="#FF75FFAF" FontSize="14"/>
                            </Grid>
                            <Grid Grid.Column="2" Margin="0, 0, 10, 0">
                                <Button x:Name="ButTheme" Content="Тема" VerticalAlignment="Top"
                                        Width="70" Height="30" Click="ButTheme_Click"
                                        FontFamily="Cascadia Code" FontWeight="Bold" FontSize="14"/>
                            </Grid>
                            <Grid Grid.Column="3">
                                <Button x:Name="ButLang" Content="RU/EN" VerticalAlignment="Top"
                                        Width="70" Height="30" Click="ButLang_Click"
                                        FontFamily="Cascadia Code" FontWeight="Bold" FontSize="14"/>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- ===== ПРАВАЯ КОЛОНКА: очередь загрузок ===== -->
            <Border Grid.Column="1" BorderBrush="#FF3A3A3A" BorderThickness="1,0,0,0"
                    Background="#FF1A1A1A" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>

                    <Label Content="Очередь загрузок" Grid.Row="0"
                           FontFamily="Cascadia Code" FontSize="18" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center"
                           Margin="0,5,0,10" Padding="0"/>

                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TextBoxQueueUrl" Grid.Column="0" Height="28"
                                 FontSize="14" FontFamily="Cascadia Code SemiLight"
                                 VerticalContentAlignment="Center" Background="White"
                                 Margin="0,0,5,0"
                                 ToolTip="Ссылка на видео для добавления в очередь"
                                 KeyDown="TextBoxQueueUrl_KeyDown"/>
                        <Button x:Name="ButAddToQueue" Grid.Column="1" Content="Добавить"
                                Width="80" Height="28" FontFamily="Cascadia Code"
                                FontSize="13" FontWeight="Bold" Click="ButAddToQueue_Click"/>
                    </Grid>

                    <ListView x:Name="ListViewQueue" Grid.Row="2"
                              Background="#FF222222" BorderThickness="0"
                              FontFamily="Cascadia Code" FontSize="12" Foreground="White"
                              SelectionMode="Extended">
                        <ListView.ItemTemplate>
                            <DataTemplate DataType="ctrl:QueueItem">
                                <Border Padding="4,3" BorderBrush="#FF333333" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="30" Height="24"
                                                Background="#FF333333" CornerRadius="3"
                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="▸" FontSize="14" TextAlignment="Center"
                                                       VerticalAlignment="Center" Foreground="#FFAAAAAA"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                                    Margin="6,0,0,0">
                                            <TextBlock Text="{Binding Title, Mode=OneWay}"
                                                       FontWeight="Bold" TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis" FontSize="12"/>
                                            <TextBlock Text="{Binding Status, Mode=OneWay}"
                                                       FontSize="11" Foreground="#FF888888"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="✕" Width="22" Height="22"
                                                Background="Transparent" Foreground="#FF888888"
                                                BorderThickness="0" FontSize="12" Padding="0"
                                                Click="ButRemoveQueueItem_Click"
                                                Tag="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel Grid.Row="3" Margin="0,8,0,0">
                        <TextBlock x:Name="TextQueueStatus" Text="" Foreground="#FF888888"
                                   FontFamily="Cascadia Code" FontSize="12"
                                   HorizontalAlignment="Center" Margin="0,0,0,5"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="ButStartQueue" Grid.Column="0" Content="Скачать всё"
                                    Height="34" FontFamily="Cascadia Code" FontSize="15"
                                    FontWeight="Bold" Background="#FFFF4F4F" Foreground="White"
                                    Margin="0,0,5,0" Click="ButStartQueue_Click"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="ButClearQueue" Content="Очистить" Width="70"
                                        Height="34" FontFamily="Cascadia Code" FontSize="13"
                                        FontWeight="Bold" Margin="0,0,5,0"
                                        Click="ButClearQueue_Click"/>
                                <Button x:Name="ButStopQueue" Content="Стоп" Width="55"
                                        Height="34" FontFamily="Cascadia Code" FontSize="13"
                                        FontWeight="Bold" Background="#FF4F4F4F"
                                        Foreground="White" Click="ButStopQueue_Click"
                                        IsEnabled="False"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>
