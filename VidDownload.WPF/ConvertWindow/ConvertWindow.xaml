<Window x:Class="VidDownload.WPF.ConvertWindow.ConvertWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:converters="clr-namespace:VidDownload.WPF.Converters"
        xmlns:res="clr-namespace:VidDownload.WPF.Resources"
        mc:Ignorable="d"
        Title="{x:Static res:Res.ConvertWindowTitle}" Height="450" Width="800">
    <Window.Resources>
        <converters:BooleanInvertConverter x:Key="InvertBool"/>
    </Window.Resources>
    <Grid Background="#FF1D1D1D">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="20, 20, 0, 0">
            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                <Label Content="{x:Static res:Res.SelectVideoFileLabel}" Background="#FF1D1D1D" Foreground="White" BorderBrush="{x:Null}" FontFamily="Cascadia Code" HorizontalContentAlignment="Left" FontSize="16" Height="36" FontWeight="Bold"/>
                <Button Content="{x:Static res:Res.BrowseButton}" Command="{Binding BrowseFileCommand}" IsEnabled="{Binding IsConverting, Converter={StaticResource InvertBool}}" Width="100" FontFamily="Cascadia Code" FontSize="14"/>
                <hc:TextBox Text="{Binding FilePath}" Width="450" Height="100" Margin="10, 0, 0, 0" Background="#FF363535" Foreground="#FFBAF79F" BorderBrush="{x:Null}" FontFamily="Cascadia Code" HorizontalContentAlignment="Left" AllowDrop="True" TextWrapping="Wrap" TextAlignment="Left" VerticalAlignment="Top" VerticalContentAlignment="Top"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1" Margin="20,20,20,20">
            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                <Label Content="{x:Static res:Res.ExtensionLabel}" Margin="10, 0, 0, 0" HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="White" FontFamily="Cascadia Code" Height="29" FontSize="16" FontWeight="Bold" Background="{x:Null}" Padding="0,0,0,0" UseLayoutRounding="False" BorderThickness="0,0,0,0"/>
                <ComboBox ItemsSource="{Binding Formats}" SelectedItem="{Binding SelectedFormat}" IsEnabled="{Binding IsConverting, Converter={StaticResource InvertBool}}" Height="22" Margin="20, 0" VerticalAlignment="Top" HorizontalAlignment="Left" Width="150" FontFamily="Cascadia Code" FontWeight="Bold" Background="White" BorderThickness="0,0,0,0" FontSize="14"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="2" Margin="20,0,20,20" VerticalAlignment="Bottom">
            <StackPanel Orientation="Vertical">
                <Label Content="{Binding StatusMessage}" Width="610" HorizontalAlignment="Center" Margin="20,0,20,0" FontFamily="Cascadia Code SemiLight" Foreground="White" Background="{x:Null}" Padding="0,0,0,0" BorderThickness="0,0,0,0" ScrollViewer.VerticalScrollBarVisibility="Disabled"/>
                <ProgressBar Value="{Binding ProgressPercent}" Margin="20, 0" Height="28" VerticalAlignment="Top" Foreground="#FDFF5252" FontFamily="Cascadia Code" FontWeight="Bold" FontSize="14"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="3" Margin="20,0,20,20" VerticalAlignment="Bottom">
            <StackPanel Orientation="Vertical">
                <Button Content="{x:Static res:Res.ConvertButton}" Command="{Binding ConvertCommand}" VerticalAlignment="Top" Margin="0, 10" Height="45" Width="300" Background="#FFFF4F4F" Foreground="White" BorderBrush="White" FontFamily="Cascadia Code" FontSize="27" FontWeight="Bold"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
