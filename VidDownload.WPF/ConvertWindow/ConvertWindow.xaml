<Window x:Class="VidDownload.WPF.ConvertWindow.ConvertWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:converters="clr-namespace:VidDownload.WPF.Converters"
        mc:Ignorable="d"
        Title="{Binding LocalizedStrings[ConvertWindowTitle]}" Height="720" Width="820"
        ResizeMode="CanMinimize" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <converters:BooleanInvertConverter x:Key="InvertBool"/>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF888888"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,14,0,4"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFCCCCCC"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>
        <Style x:Key="DarkInput" TargetType="TextBox">
            <Setter Property="Background" Value="#FF2D2D2D"/>
            <Setter Property="Foreground" Value="#FFBAF79F"/>
            <Setter Property="BorderBrush" Value="#FF3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Cascadia Code"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#FF2D2D2D"/>
            <Setter Property="Foreground" Value="#FFBAF79F"/>
            <Setter Property="BorderBrush" Value="#FF3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Cascadia Code"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="26"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="#FF3A3A3A"/>
            <Setter Property="Foreground" Value="#FFCCCCCC"/>
            <Setter Property="BorderBrush" Value="#FF505050"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    <Grid Background="#FF1A1A1A">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="24"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="24"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════ INPUT SECTION ═══════ -->
        <StackPanel Grid.Row="0" Grid.Column="1">
            <TextBlock Text="{Binding LocalizedStrings[InputSectionLabel]}" Style="{StaticResource SectionHeader}"/>
            <Rectangle Height="1" Fill="#FF333333" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding LocalizedStrings[SelectVideoFileLabel]}" Style="{StaticResource FieldLabel}"/>
                <Button Content="{Binding LocalizedStrings[BrowseButton]}"
                        Command="{Binding BrowseFileCommand}"
                        IsEnabled="{Binding IsConverting, Converter={StaticResource InvertBool}}"
                        Style="{StaticResource ActionButton}" Margin="6,0,6,0"/>
                <TextBox Text="{Binding FilePath}" Width="540"
                         Style="{StaticResource DarkInput}" AllowDrop="True"/>
            </StackPanel>
        </StackPanel>

        <!-- ═══════ OUTPUT SECTION ═══════ -->
        <StackPanel Grid.Row="1" Grid.Column="1">
            <TextBlock Text="{Binding LocalizedStrings[OutputSectionLabel]}" Style="{StaticResource SectionHeader}"/>
            <Rectangle Height="1" Fill="#FF333333" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="{Binding LocalizedStrings[OutputFolderLabel]}" Style="{StaticResource FieldLabel}"/>
                <Button Content="{Binding LocalizedStrings[OutputBrowseButton]}"
                        Command="{Binding BrowseOutputDirCommand}"
                        IsEnabled="{Binding IsConverting, Converter={StaticResource InvertBool}}"
                        Style="{StaticResource ActionButton}" Margin="6,0,6,0"/>
                <TextBox Text="{Binding OutputDirectory}" Width="330"
                         Style="{StaticResource DarkInput}"/>
                <TextBlock Text="{Binding LocalizedStrings[OutputFileNameLabel]}" Style="{StaticResource FieldLabel}" Margin="12,0,4,0"/>
                <TextBox Text="{Binding OutputFileName}"
                         Style="{StaticResource DarkInput}" Width="144"/>
            </StackPanel>
        </StackPanel>

        <!-- ═══════ ENCODING SECTION ═══════ -->
        <StackPanel Grid.Row="2" Grid.Column="1">
            <TextBlock Text="{Binding LocalizedStrings[EncodingSectionLabel]}" Style="{StaticResource SectionHeader}"/>
            <Rectangle Height="1" Fill="#FF333333" Margin="0,0,0,8"/>

            <!-- Row 1: Format | Hardware encoder | Preset -->
            <StackPanel Orientation="Horizontal" Margin="0,4">
                <TextBlock Text="{Binding LocalizedStrings[ExtensionLabel]}" Style="{StaticResource FieldLabel}"/>
                <ComboBox ItemsSource="{Binding Formats}" SelectedItem="{Binding SelectedFormat}"
                          IsEnabled="{Binding IsConverting, Converter={StaticResource InvertBool}}"
                          Width="90" hc:Theme.Skin="Dark"/>

                <TextBlock Text="{Binding LocalizedStrings[HardwareEncoderLabel]}" Style="{StaticResource FieldLabel}" Margin="20,0,4,0"/>
                <ComboBox ItemsSource="{Binding HardwareEncoders}" SelectedItem="{Binding SelectedHardwareEncoder}"
                          IsEnabled="{Binding IsConverting, Converter={StaticResource InvertBool}}"
                          Width="100" hc:Theme.Skin="Dark"/>

                <TextBlock Text="{Binding LocalizedStrings[PresetLabel]}" Style="{StaticResource FieldLabel}" Margin="20,0,4,0"/>
                <ComboBox ItemsSource="{Binding Presets}" SelectedItem="{Binding SelectedPreset}"
                          IsEnabled="{Binding IsConverting, Converter={StaticResource InvertBool}}"
                          Width="130" hc:Theme.Skin="Dark"/>
            </StackPanel>

            <!-- Row 2: Video codec | Audio codec -->
            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                <TextBlock Text="{Binding LocalizedStrings[VideoCodecLabel]}" Style="{StaticResource FieldLabel}"/>
                <ComboBox ItemsSource="{Binding VideoCodecs}" SelectedItem="{Binding SelectedVideoCodec}"
                          IsEnabled="{Binding IsConverting, Converter={StaticResource InvertBool}}"
                          Width="210" hc:Theme.Skin="Dark"/>

                <TextBlock Text="{Binding LocalizedStrings[AudioCodecLabel]}" Style="{StaticResource FieldLabel}" Margin="20,0,4,0"/>
                <ComboBox ItemsSource="{Binding AudioCodecs}" SelectedItem="{Binding SelectedAudioCodec}"
                          IsEnabled="{Binding IsConverting, Converter={StaticResource InvertBool}}"
                          Width="150" hc:Theme.Skin="Dark"/>
            </StackPanel>
        </StackPanel>

        <!-- ═══════ QUALITY SECTION ═══════ -->
        <StackPanel Grid.Row="4" Grid.Column="1">
            <TextBlock Text="{Binding LocalizedStrings[QualitySectionLabel]}" Style="{StaticResource SectionHeader}"/>
            <Rectangle Height="1" Fill="#FF333333" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" Margin="0,4">
                <TextBlock Text="{Binding LocalizedStrings[CrfLabel]}" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding Crf, UpdateSourceTrigger=PropertyChanged}" Width="44"
                         IsEnabled="{Binding IsConverting, Converter={StaticResource InvertBool}}"
                         Style="{StaticResource DarkInput}" Margin="0,0,4,0"
                         ToolTip="{Binding LocalizedStrings[CrfHint]}"/>

                <TextBlock Text="{Binding LocalizedStrings[VideoBitrateLabel]}" Style="{StaticResource FieldLabel}" Margin="20,0,4,0"/>
                <TextBox Text="{Binding VideoBitrate, UpdateSourceTrigger=PropertyChanged}" Width="64"
                         IsEnabled="{Binding IsConverting, Converter={StaticResource InvertBool}}"
                         Style="{StaticResource DarkInput}" Margin="0,0,4,0"
                         ToolTip="{Binding LocalizedStrings[VideoBitrateHint]}"/>

                <TextBlock Text="{Binding LocalizedStrings[AudioBitrateLabel]}" Style="{StaticResource FieldLabel}" Margin="20,0,4,0"/>
                <TextBox Text="{Binding AudioBitrate, UpdateSourceTrigger=PropertyChanged}" Width="64"
                         IsEnabled="{Binding IsConverting, Converter={StaticResource InvertBool}}"
                         Style="{StaticResource DarkInput}" Margin="0,0,4,0"
                         ToolTip="{Binding LocalizedStrings[AudioBitrateHint]}"/>
            </StackPanel>
        </StackPanel>

        <!-- ═══════ COMMAND PREVIEW ═══════ -->
        <StackPanel Grid.Row="5" Grid.Column="1">
            <TextBlock Text="{Binding LocalizedStrings[FfmpegCommandPreviewLabel]}" Style="{StaticResource SectionHeader}"/>
            <Rectangle Height="1" Fill="#FF333333" Margin="0,0,0,4"/>
            <TextBox Text="{Binding FfmpegCommandPreview}" Height="48"
                     Background="#FF222222" Foreground="#FF6BCAE2"
                     BorderBrush="#FF333333" BorderThickness="1"
                     FontFamily="Consolas" FontSize="11"
                     IsReadOnly="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"/>
        </StackPanel>

        <!-- ═══════ PROGRESS ═══════ -->
        <StackPanel Grid.Row="7" Grid.Column="1" Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusMessage}" HorizontalAlignment="Center"
                       FontFamily="Segoe UI" FontSize="12"
                       Foreground="#FF999999" Margin="0,4"/>
            <ProgressBar Value="{Binding ProgressPercent}" Height="20"
                         Foreground="#FDFF5252" Margin="0,2" hc:Theme.Skin="Dark"/>
        </StackPanel>

        <!-- ═══════ BUTTONS ═══════ -->
        <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,10,0,16">
            <Button Content="{Binding LocalizedStrings[CancelConvertButton]}"
                    Command="{Binding CancelConvertCommand}"
                    IsEnabled="{Binding IsCancellable}"
                    Visibility="{Binding IsCancellable, Converter={StaticResource BoolToVis}}"
                    Width="150" Height="38"
                    Background="#FFCC6600" Foreground="White"
                    BorderBrush="#FFE67A00" BorderThickness="1"
                    FontFamily="Segoe UI" FontSize="15" FontWeight="Bold"
                    Cursor="Hand" Margin="0,0,12,0"/>
            <Button Content="{Binding LocalizedStrings[ConvertButton]}"
                    Command="{Binding ConvertCommand}"
                    Width="260" Height="44"
                    Background="#FFD94040" Foreground="White"
                    BorderBrush="#FFF06060" BorderThickness="1"
                    FontFamily="Segoe UI" FontSize="18" FontWeight="Bold"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
