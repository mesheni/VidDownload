```gitignore
# Build artifacts and binaries
*.exe
*.dll
*.pdb
*.nupkg
**/bin/
**/obj/
**/Debug/
**/Release/

# Dependencies
packages/
node_modules/
vendor/

# Logs and temp files
*.log
*.tmp
*.temp

# User-specific files
*.user
*.userosscache
*.suo
*.userprefs

# Environment
.env
.env.local
*.env.*

# Editors
.vs/
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db
ehthumbs.db
Icon?
```